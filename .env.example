# MedFusion AI Environment Variables Template
# Copy this file to .env in your local environment or configure them in your cloud provider dashboard (Vercel & Render).

# ==================== BACKEND CONFIGURATION ====================
# MongoDB Connection URI (MongoDB Atlas or local instance)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/medfusion

# Secret key used for signing JWT Authentication tokens
JWT_SECRET=your-super-secure-jwt-secret-key-change-this-in-production

# Google Gemini API Key for NLP and OCR clinical report intelligence
GEMINI_API_KEY=AIzaSy...

# Cloudinary URL for permanent medical scan/image upload storage
# Format: cloudinary://<api_key>:<api_secret>@<cloud_name>
CLOUDINARY_URL=

# ==================== FRONTEND CONFIGURATION ====================
# Public URL of the FastAPI backend service (used by Next.js frontend client-side)
# In production, set this to your Render service URL (e.g., https://medfusion-backend.onrender.com)
NEXT_PUBLIC_API_URL=http://localhost:8001
